{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Properdocs - Générer le site (config PROD)",
            "group": "build",
            "command": "${command:python.interpreterPath}",
            "args": [
                "-m",
                "properdocs",
                "build",
                "--strict",
                "--config-file",
                "propderdocs.yml"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "Properdocs - Servir le site localement (config MINIMALE)",
            "group": "test",
            "command": "${command:python.interpreterPath}",
            "args": [
                "-m",
                "properdocs",
                "serve",
                "-f",
                "mkdocs-minimal.yml",
                "--dirtyreload"
            ],
            "presentation": {
                "echo": true,
                "reveal": "silent",
                "focus": true,
                "panel": "dedicated",
                "showReuseMessage": true,
                "clear": true
            },
            "problemMatcher": []
        }
    ]
}
